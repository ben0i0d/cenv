// For format details, see https://aka.ms/devcontainer.json. 
// For config options, see the README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
	"name": "sql",
	
	"image": "codeberg.org/eoelab/cenv:sql",

	// Support for pip_cache
	"containerEnv": {
		"PIP_CACHE_DIR": "${containerWorkspaceFolder}/.cache/pip"
	},

	// Configure vscode-extensions.
	"customizations": {
		"vscode": {
		  "extensions": ["ms-python.python", "ms-python.vscode-pylance", "ms-toolsai.jupyter", "cweijan.vscode-mysql-client2"]
		}
	  },
	"onCreateCommand": "curl -fsSL https://codeberg.org/eoelab/cenv/raw/branch/main/.setup/base.sh | sh",
	"updateContentCommand": "curl -fsSL https://codeberg.org/eoelab/cenv/raw/branch/main/.setup/python.sh | sh",
	"postCreateCommand": "sh mysql_init.sh",
	"postStartCommand": "sh mysql_start.sh"
}