// For format details, see https://aka.ms/devcontainer.json. 
// For config options, see the README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
	"name": "uv",
	
	"image": "codeberg.org/eoelab/cenv:uv",

	// Support for uv mirror & cache
	"containerEnv": {
		"UV_INDEX_URL": "https://mirrors.ustc.edu.cn/pypi/simple",
		"UV_CACHE_DIR": "${containerWorkspaceFolder}/.cache/uv"
	},

	// Configure vscode-extensions.
	"customizations": {
		"vscode": {
		  "extensions": ["ms-python.python", "ms-python.vscode-pylance", "ms-toolsai.jupyter"]
		}
	  },
	"onCreateCommand": "curl -fsSL https://codeberg.org/eoelab/cenv/raw/branch/main/.bootstrap/uv.sh | sh"
}