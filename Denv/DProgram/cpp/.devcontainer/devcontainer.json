// For format details, see https://aka.ms/devcontainer.json. 
// For config options, see the README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
	"name": "cpp",
	
	"image": "codeberg.org/eoelab/cenv:cpp",

	// Support for ccache & cmake
	"containerEnv": {
		"PATH": "/usr/lib/ccache:$PATH",
		"CCACHE_DIR": "${containerWorkspaceFolder}/.cache/ccache",
		"CMAKE_C_COMPILER_LAUNCHER": "ccache",
		"CMAKE_CXX_COMPILER_LAUNCHER": "ccache"
	},

	// Configure vscode-extensions.
	"customizations": {
		"vscode": {
		  "extensions": ["ms-vscode.cpptools-extension-pack"]
		}
	  },
	"onCreateCommand": "curl -fsSL https://codeberg.org/eoelab/cenv/raw/branch/main/.bootstrap/ccache.sh | sh"
}