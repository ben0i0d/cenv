// For format details, see https://aka.ms/devcontainer.json. 
// For config options, see the README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
	"name": "mysql",
	
	"image": "codeberg.org/eoelab/cenv:mysql",

	// port-forward to host
	"forwardPorts": [3306],

	// storage data with workspace
	"onCreateCommand": "mkdir -p .mysql && mysql_install_db --user=root --datadir=${containerWorkspaceFolder}/.mysql",
	"postStartCommand": "mariadbd --user=root --datadir=${containerWorkspaceFolder}/.mysql --bind-address=0.0.0.0"
}